<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        survey.certification_report_view is an ir.ui.view (QWeb template).
        We inherit it and replace its entire rendered output.

        Template variables (survey report model):
            docs                      — recordset of survey.user_input
            input                     — current record (via t-foreach)
            input.partner_id.name     — student name
            input.survey_id.title     — certification title
            input.create_date         — completion datetime
            res_company, user, time   — standard report globals
    -->

    <template id="report_shafa_certificate"
              inherit_id="survey.certification_report_view">

        <xpath expr="//t[@t-call='web.html_container']" position="replace">

            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="input">

                    <!-- Required by Odoo's report engine for per-record
                         PDF splitting and attachment saving. -->
                    <div class="article"
                         t-att-data-oe-model="input._name"
                         t-att-data-oe-id="input.id"
                         style="padding:0;margin:0;border:none;display:block;">

                        <style type="text/css">

                            /* ---- Force background colours to print in wkhtmltopdf ---- */
                            * {
                                box-sizing: border-box;
                                margin: 0;
                                padding: 0;
                                -webkit-print-color-adjust: exact !important;
                                print-color-adjust: exact !important;
                            }

                            /* Reset Odoo article padding */
                            div.article {
                                padding: 0 !important;
                                margin: 0 !important;
                                border: none !important;
                            }

                            @page {
                                size: 297mm 210mm;
                                margin: 0mm;
                            }

                            body { margin: 0; padding: 0; }

                            /* ================================================================
                               OUTER WRAPPER — CSS TABLE so wkhtmltopdf renders two columns
                               reliably (flexbox has partial support; table is rock-solid).
                            ================================================================ */
                            .cert-table {
                                display: table;
                                width: 297mm;
                                height: 210mm;
                                border-collapse: collapse;
                                font-family: Arial, Helvetica, sans-serif;
                                background: #ffffff;
                                border: 1.5px solid #d5d5d5;
                                position: relative;
                                overflow: hidden;
                            }

                            .cert-row { display: table-row; }

                            /* ---- Left content column ---- */
                            .cert-main {
                                display: table-cell;
                                vertical-align: top;
                                padding: 16mm 12mm 12mm 16mm;
                                position: relative;
                            }

                            /* ---- Right grey panel ---- */
                            .cert-side {
                                display: table-cell;
                                width: 58mm;
                                background-color: #ebebeb !important;
                                vertical-align: middle;
                                text-align: center;
                                padding: 12mm 6mm;
                            }

                            /* ================================================================
                               LEFT PANEL CONTENT
                            ================================================================ */
                            .cert-logo {
                                height: 48px;
                                max-width: 155px;
                                display: block;
                                margin-bottom: 8px;
                            }

                            .cert-platform {
                                font-size: 20pt;
                                font-weight: 300;
                                color: #222;
                                margin-bottom: 4px;
                                line-height: 1.2;
                            }

                            .cert-date {
                                font-size: 10pt;
                                color: #555;
                                margin-bottom: 14px;
                            }

                            .cert-student {
                                font-size: 26pt;
                                font-weight: 700;
                                color: #1a1a1a;
                                margin-bottom: 5px;
                                line-height: 1.1;
                            }

                            .cert-completed {
                                font-size: 10.5pt;
                                color: #555;
                                margin-bottom: 5px;
                            }

                            .cert-course {
                                font-size: 15pt;
                                font-weight: 700;
                                color: #1a1a1a;
                                margin-bottom: 4px;
                            }

                            .cert-authorised {
                                font-size: 10pt;
                                color: #555;
                            }

                            /* Spacer pushes signature to the bottom of the left cell */
                            .cert-spacer { height: 18mm; }

                            .cert-sig-line {
                                width: 85px;
                                border-bottom: 1.2px solid #888;
                                margin-bottom: 4px;
                            }

                            .cert-sig-name {
                                font-size: 13pt;
                                font-style: italic;
                                font-family: Georgia, 'Times New Roman', serif;
                                font-weight: 600;
                                color: #2a2a2a;
                            }

                            .cert-sig-role {
                                font-size: 9pt;
                                color: #333;
                                line-height: 1.5;
                            }

                            /* ================================================================
                               RIGHT PANEL CONTENT
                            ================================================================ */
                            .cert-badge {
                                font-size: 12pt;
                                font-weight: 400;
                                letter-spacing: 1.5px;
                                color: #2a2a2a;
                                text-transform: uppercase;
                                line-height: 1.6;
                                margin-bottom: 20mm;
                            }

                            .cert-emblem {
                                width: 68px;
                                height: 68px;
                            }

                            /* ================================================================
                               WATERMARK — absolutely inside the left cell
                               Circles are small (r=45 in a 760-wide viewBox ≈ 18mm radius)
                               and very light.
                            ================================================================ */
                            .cert-watermark-wrap {
                                position: absolute;
                                top: 0; left: 0;
                                width: 100%; height: 100%;
                                overflow: hidden;
                                pointer-events: none;
                            }

                        </style>

                        <div class="cert-table">
                            <div class="cert-row">

                                <!-- ============================================================
                                     LEFT PANEL
                                ============================================================ -->
                                <div class="cert-main">

                                    <!-- Watermark circles inside the left cell -->
                                    <div class="cert-watermark-wrap">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             width="100%" height="100%"
                                             viewBox="0 0 760 560"
                                             preserveAspectRatio="xMidYMid slice">
                                            <circle cx="80"  cy="80"  r="45" fill="none" stroke="#ccc" stroke-width="12" opacity="0.45"/>
                                            <circle cx="310" cy="175" r="38" fill="none" stroke="#ccc" stroke-width="12" opacity="0.35"/>
                                            <circle cx="490" cy="70"  r="32" fill="none" stroke="#ccc" stroke-width="12" opacity="0.35"/>
                                            <circle cx="70"  cy="390" r="40" fill="none" stroke="#ccc" stroke-width="12" opacity="0.35"/>
                                            <circle cx="300" cy="460" r="30" fill="none" stroke="#ccc" stroke-width="12" opacity="0.30"/>
                                            <circle cx="470" cy="390" r="26" fill="none" stroke="#ccc" stroke-width="10" opacity="0.28"/>
                                        </svg>
                                    </div>

                                    <!-- Logo -->
                                    <t t-if="res_company.logo">
                                        <img class="cert-logo"
                                             t-att-src="'/web/image/res.company/%d/logo' % res_company.id"
                                             alt="Logo"/>
                                    </t>

                                    <!-- Platform name -->
                                    <div class="cert-platform">A.Y.M Shafa eLearning</div>

                                    <!-- Date -->
                                    <div class="cert-date">
                                        <t t-if="input.create_date">
                                            <t t-esc="input.create_date.strftime('%d/%m/%Y')"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="time.strftime('%d/%m/%Y')"/>
                                        </t>
                                    </div>

                                    <!-- Student name -->
                                    <div class="cert-student">
                                        <t t-if="input.partner_id">
                                            <t t-esc="input.partner_id.name"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="user.partner_id.name"/>
                                        </t>
                                    </div>

                                    <div class="cert-completed">has successfully completed</div>

                                    <!-- Course title -->
                                    <div class="cert-course">
                                        <t t-esc="input.survey_id.title"/>
                                    </div>

                                    <div class="cert-authorised">
                                        an online course authorised by A.Y.M Shafa Limited
                                    </div>

                                    <!-- Spacer then signature -->
                                    <div class="cert-spacer"/>

                                    <div class="cert-sig-line"/>
                                    <div class="cert-sig-name">Ali Ibrahim</div>
                                    <div class="cert-sig-role">MD/COO</div>
                                    <div class="cert-sig-role">AYM Shafa Limited</div>

                                </div><!-- /cert-main -->

                                <!-- ============================================================
                                     RIGHT GREY PANEL
                                ============================================================ -->
                                <div class="cert-side">

                                    <div class="cert-badge">
                                        VERIFIED<br/>CERTIFICATE
                                    </div>

                                    <!--
                                        Shafa mandala: 12 outer petals (orange #E85520)
                                        + 12 inner petals (deep red #C43A0F, +15°)
                                        + hollow grey centre.
                                    -->
                                    <svg class="cert-emblem"
                                         xmlns="http://www.w3.org/2000/svg"
                                         viewBox="0 0 100 100">
                                        <g transform="translate(50,50)">
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(0)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(30)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(60)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(90)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(120)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(150)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(180)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(210)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(240)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(270)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(300)"/>
                                            <path d="M0,-44 C9,-33 9,-20 0,-14 C-9,-20 -9,-33 0,-44Z" fill="#E85520" transform="rotate(330)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(15)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(45)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(75)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(105)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(135)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(165)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(195)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(225)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(255)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(285)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(315)"/>
                                            <path d="M0,-26 C5,-19 5,-11 0,-8 C-5,-11 -5,-19 0,-26Z" fill="#C43A0F" transform="rotate(345)"/>
                                            <circle r="9" fill="#ebebeb"/>
                                        </g>
                                    </svg>

                                </div><!-- /cert-side -->

                            </div><!-- /cert-row -->
                        </div><!-- /cert-table -->

                    </div><!-- /article -->

                </t><!-- /t-foreach -->
            </t><!-- /web.html_container -->

        </xpath>
    </template>

</odoo>
